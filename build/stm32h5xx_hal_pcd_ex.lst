  64:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_pcd_ex.c ****   * @brief  Set Tx FIFO
  65:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_pcd_ex.c ****   * @param  hpcd PCD handle
  66:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_pcd_ex.c ****   * @param  fifo The number of Tx fifo
  67:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_pcd_ex.c ****   * @param  size Fifo size
  68:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_pcd_ex.c ****   * @retval HAL status
  69:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_pcd_ex.c ****   */
  70:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_pcd_ex.c **** HAL_StatusTypeDef HAL_PCDEx_SetTxFiFo(PCD_HandleTypeDef *hpcd, uint8_t fifo, uint16_t size)
  71:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_pcd_ex.c **** {
  72:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_pcd_ex.c ****   uint8_t i;
  73:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_pcd_ex.c ****   uint32_t Tx_Offset;
  74:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_pcd_ex.c **** 
  75:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_pcd_ex.c ****   /*  TXn min size = 16 words. (n  : Transmit FIFO index)
  76:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_pcd_ex.c ****       When a TxFIFO is not used, the Configuration should be as follows:
  77:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_pcd_ex.c ****           case 1 :  n > m    and Txn is not used    (n,m  : Transmit FIFO indexes)
  78:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_pcd_ex.c ****          --> Txm can use the space allocated for Txn.
  79:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_pcd_ex.c ****          case2  :  n < m    and Txn is not used    (n,m  : Transmit FIFO indexes)
  80:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_pcd_ex.c ****          --> Txn should be configured with the minimum space of 16 words
  81:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_pcd_ex.c ****      The FIFO is used optimally when used TxFIFOs are allocated in the top
  82:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_pcd_ex.c ****          of the FIFO.Ex: use EP1 and EP2 as IN instead of EP1 and EP3 as IN ones.
  83:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_pcd_ex.c ****      When DMA is used 3n * FIFO locations should be reserved for internal DMA registers */
  84:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_pcd_ex.c **** 
  85:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_pcd_ex.c ****   Tx_Offset = hpcd->Instance->GRXFSIZ;
ARM GAS  C:\Users\DELL\AppData\Local\Temp\cc9Si68j.s 			page 3


  86:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_pcd_ex.c **** 
  87:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_pcd_ex.c ****   if (fifo == 0U)
  88:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_pcd_ex.c ****   {
  89:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_pcd_ex.c ****     hpcd->Instance->DIEPTXF0_HNPTXFSIZ = ((uint32_t)size << 16) | Tx_Offset;
  90:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_pcd_ex.c ****   }
  91:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_pcd_ex.c ****   else
  92:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_pcd_ex.c ****   {
  93:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_pcd_ex.c ****     Tx_Offset += (hpcd->Instance->DIEPTXF0_HNPTXFSIZ) >> 16;
  94:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_pcd_ex.c ****     for (i = 0U; i < (fifo - 1U); i++)
  95:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_pcd_ex.c ****     {
  96:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_pcd_ex.c ****       Tx_Offset += (hpcd->Instance->DIEPTXF[i] >> 16);
  97:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_pcd_ex.c ****     }
  98:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_pcd_ex.c **** 
  99:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_pcd_ex.c ****     /* Multiply Tx_Size by 2 to get higher performance */
 100:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_pcd_ex.c ****     hpcd->Instance->DIEPTXF[fifo - 1U] = ((uint32_t)size << 16) | Tx_Offset;
 101:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_pcd_ex.c ****   }
 102:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_pcd_ex.c **** 
 103:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_pcd_ex.c ****   return HAL_OK;
 104:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_pcd_ex.c **** }
