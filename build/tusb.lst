  53:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h **** 
  54:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h **** // Due to the use of unmasked pointers, this FIFO does not suffer from losing
  55:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h **** // one item slice. Furthermore, write and read operations are completely
  56:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h **** // decoupled as write and read functions do not modify a common state. Henceforth,
  57:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h **** // writing or reading from the FIFO within an ISR is safe as long as no other
  58:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h **** // process (thread or ISR) interferes.
  59:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h **** // Also, this FIFO is ready to be used in combination with a DMA as the write and
  60:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h **** // read pointers can be updated from within a DMA ISR. Overflows are detectable
  61:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h **** // within a certain number (see tu_fifo_overflow()).
  62:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h **** 
  63:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h **** /* Write/Read "pointer" is in the range of: 0 .. depth - 1, and is used to get the fifo data.
  64:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  * Write/Read "index" is always in the range of: 0 .. 2*depth-1
  65:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  *
  66:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  * The extra window allow us to determine the fifo state of empty or full with only 2 indices
ARM GAS  C:\Users\DELL\AppData\Local\Temp\cctswona.s 			page 57


  67:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  * Following are examples with depth = 3
  68:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  *
  69:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  * - empty: W = R
  70:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  *                |
  71:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  *    -------------------------
  72:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  *    | 0 | RW| 2 | 3 | 4 | 5 |
  73:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  *
  74:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  * - full 1: W > R
  75:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  *                |
  76:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  *    -------------------------
  77:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  *    | 0 | R | 2 | 3 | W | 5 |
  78:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  *
  79:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  * - full 2: W < R
  80:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  *                |
  81:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  *    -------------------------
  82:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  *    | 0 | 1 | W | 3 | 4 | R |
  83:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  *
  84:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  * - Number of items in the fifo can be determined in either cases:
  85:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  *    - case W >= R: Count = W - R
  86:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  *    - case W <  R: Count = 2*depth - (R - W)
  87:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  *
  88:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  * In non-overwritable mode, computed Count (in above 2 cases) is at most equal to depth.
  89:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  * However, in over-writable mode, write index can be repeatedly increased and count can be
  90:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  * temporarily larger than depth (overflowed condition) e.g
  91:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  *
  92:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  *  - Overflowed 1: write(3), write(1)
  93:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  *    In this case we will adjust Read index when read()/peek() is called so that count = depth.
  94:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  *                  |
  95:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  *      -------------------------
  96:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  *      | R | 1 | 2 | 3 | W | 5 |
  97:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  *
  98:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  *  - Double Overflowed i.e index is out of allowed range [0,2*depth)
  99:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  *    This occurs when we continue to write after 1st overflowed to 2nd overflowed. e.g:
 100:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  *      write(3), write(1), write(2)
 101:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  *    This must be prevented since it will cause unrecoverable state, in above example
 102:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  *    if not handled the fifo will be empty instead of continue-to-be full. Since we must not modif
 103:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  *    read index in write() function, which cause race condition. We will re-position write index s
 104:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  *    after data is written it is a full fifo i.e W = depth - R
 105:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  *
 106:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  *      re-position W = 1 before write(2)
 107:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  *      Note: we should also move data from mem[3] to read index as well, but deliberately skipped 
 108:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  *      since it is an expensive operation !!!
 109:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  *                  |
 110:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  *      -------------------------
 111:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  *      | R | W | 2 | 3 | 4 | 5 |
 112:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  *
 113:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  *      perform write(2), result is still a full fifo.
 114:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  *
 115:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  *                  |
 116:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  *      -------------------------
 117:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  *      | R | 1 | 2 | W | 4 | 5 |
 118:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****  */
 119:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h **** typedef struct {
 120:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****   uint8_t *buffer;              // buffer pointer
 121:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****   uint16_t depth;               // max items
 122:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h ****   bool     overwritable;        // overwritable when full
