 466:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_icache.c ****   [..]
 467:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_icache.c ****     This section provides functions allowing to handle ICACHE global interrupt
 468:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_icache.c ****     and the associated callback functions.
 469:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_icache.c ****   @endverbatim
 470:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_icache.c ****   * @{
 471:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_icache.c ****   */
 472:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_icache.c **** 
 473:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_icache.c **** /**
 474:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_icache.c ****   * @brief Handle the Instruction Cache interrupt request.
 475:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_icache.c ****   * @note This function should be called under the ICACHE_IRQHandler().
 476:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_icache.c ****   * @note This function respectively disables the interrupt and clears the
 477:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_icache.c ****   *       flag of any pending flag before calling the associated user callback.
 478:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_icache.c ****   * @retval None
 479:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_icache.c ****   */
 480:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_icache.c **** void HAL_ICACHE_IRQHandler(void)
 481:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_icache.c **** {
 482:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_icache.c ****   /* Get current interrupt flags and interrupt sources value */
 483:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_icache.c ****   uint32_t itflags   = READ_REG(ICACHE->SR);
 484:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_icache.c ****   uint32_t itsources = READ_REG(ICACHE->IER);
 485:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_icache.c **** 
 486:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_icache.c ****   /* Check Instruction cache Error interrupt flag */
 487:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_icache.c ****   if (((itflags & itsources) & ICACHE_FLAG_ERROR) != 0U)
 488:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_icache.c ****   {
 489:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_icache.c ****     /* Disable error interrupt */
 490:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_icache.c ****     CLEAR_BIT(ICACHE->IER, ICACHE_IER_ERRIE);
 491:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_icache.c **** 
 492:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_icache.c ****     /* Clear ERR pending flag */
 493:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_icache.c ****     WRITE_REG(ICACHE->FCR, ICACHE_FCR_CERRF);
