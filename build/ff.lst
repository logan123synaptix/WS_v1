1384:SynaptiX_FDK/services/fatfs/ff.c **** 			bm = 1;
1385:SynaptiX_FDK/services/fatfs/ff.c **** 		} while (++i < SS(fs));		/* Next byte */
1386:SynaptiX_FDK/services/fatfs/ff.c **** 		i = 0;
1387:SynaptiX_FDK/services/fatfs/ff.c **** 	}
1388:SynaptiX_FDK/services/fatfs/ff.c **** }
1389:SynaptiX_FDK/services/fatfs/ff.c **** 
