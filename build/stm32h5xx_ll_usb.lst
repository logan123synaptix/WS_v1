3205:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_ll_usb.c ****   for (count = NbWords; count != 0U; count--)
3206:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_ll_usb.c ****   {
3207:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_ll_usb.c ****     __UNALIGNED_UINT32_WRITE(pBuf, *pdwVal);
