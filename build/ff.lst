1349:SynaptiX_FDK/services/fatfs/ff.c **** 			bm = 1;
1350:SynaptiX_FDK/services/fatfs/ff.c **** 		} while (++i < SS(fs));
1351:SynaptiX_FDK/services/fatfs/ff.c **** 	}
1352:SynaptiX_FDK/services/fatfs/ff.c **** }
