 228:SynaptiX_FDK/services/littlefs/lfs.c **** static int lfs_bd_prog(lfs_t *lfs,
 229:SynaptiX_FDK/services/littlefs/lfs.c ****         lfs_cache_t *pcache, lfs_cache_t *rcache, bool validate,
 230:SynaptiX_FDK/services/littlefs/lfs.c ****         lfs_block_t block, lfs_off_t off,
 231:SynaptiX_FDK/services/littlefs/lfs.c ****         const void *buffer, lfs_size_t size) {
 232:SynaptiX_FDK/services/littlefs/lfs.c ****     const uint8_t *data = buffer;
 233:SynaptiX_FDK/services/littlefs/lfs.c ****     LFS_ASSERT(block == LFS_BLOCK_INLINE || block < lfs->block_count);
