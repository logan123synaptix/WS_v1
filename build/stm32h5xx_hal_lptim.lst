  26:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_lptim.c ****   ==============================================================================
  27:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_lptim.c ****                      ##### How to use this driver #####
  28:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_lptim.c ****   ==============================================================================
  29:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_lptim.c ****     [..]
