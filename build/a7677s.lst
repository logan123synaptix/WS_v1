  51:SynaptiX_FDK/components/modules/a76xx/a7677s.c **** 
  52:SynaptiX_FDK/components/modules/a76xx/a7677s.c **** /* Separate scratch buffer for MQTT dynamic commands (broker URL, topic, payload
  53:SynaptiX_FDK/components/modules/a76xx/a7677s.c ****  * length lines, etc.).  Kept separate from s_dyn_cmd_buf so an in-flight init
  54:SynaptiX_FDK/components/modules/a76xx/a7677s.c ****  * command and an MQTT command never share the same buffer — even though the
  55:SynaptiX_FDK/components/modules/a76xx/a7677s.c ****  * state machines are mutually exclusive at runtime, having distinct buffers
  56:SynaptiX_FDK/components/modules/a76xx/a7677s.c ****  * makes the invariant explicit and avoids subtle bugs during future refactors.
  57:SynaptiX_FDK/components/modules/a76xx/a7677s.c ****  * Size covers the longest possible AT+CMQTTCONNECT line:
  58:SynaptiX_FDK/components/modules/a76xx/a7677s.c ****  *   "AT+CMQTTCONNECT=0,\"tcp://<256 chars>\",64800,1,\"<256>\",\"<256>\"\r\n"
  59:SynaptiX_FDK/components/modules/a76xx/a7677s.c ****  *   = ~850 chars worst case; A7677S_MQTT_DYN_CMD_MAX is 384 which covers
  60:SynaptiX_FDK/components/modules/a76xx/a7677s.c ****  *   all practical broker URLs/credentials (broker <= 100, user/pass <= 64). */
  61:SynaptiX_FDK/components/modules/a76xx/a7677s.c **** static char s_mqtt_dyn_cmd_buf[A7677S_MQTT_DYN_CMD_MAX];
