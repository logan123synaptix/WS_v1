  37:SynaptiX_FDK/services/fatfs/ff.c **** /* Limits and boundaries */
  38:SynaptiX_FDK/services/fatfs/ff.c **** #define MAX_DIR		0x200000		/* Max size of FAT directory (byte) */
  39:SynaptiX_FDK/services/fatfs/ff.c **** #define MAX_DIR_EX	0x10000000		/* Max size of exFAT directory (byte) */
  40:SynaptiX_FDK/services/fatfs/ff.c **** #define MAX_FAT12	0xFF5			/* Max FAT12 clusters (differs from specs, but right for real DOS/Windows
  41:SynaptiX_FDK/services/fatfs/ff.c **** #define MAX_FAT16	0xFFF5			/* Max FAT16 clusters (differs from specs, but right for real DOS/Window
  42:SynaptiX_FDK/services/fatfs/ff.c **** #define MAX_FAT32	0x0FFFFFF5		/* Max FAT32 clusters (not defined in specs, practical limit) */
  43:SynaptiX_FDK/services/fatfs/ff.c **** #define MAX_EXFAT	0x7FFFFFFD		/* Max exFAT clusters (differs from specs, implementation limit) */
