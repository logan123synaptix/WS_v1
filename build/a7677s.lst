 274:SynaptiX_FDK/components/modules/a76xx/a7677s.c **** 
 275:SynaptiX_FDK/components/modules/a76xx/a7677s.c ****     log_info(TAG, "Power Off start (AT+CPOF)");
 276:SynaptiX_FDK/components/modules/a76xx/a7677s.c ****     /* No powerPin/VBAT cutoff on this board revision (hasPowerPin stays 0,
