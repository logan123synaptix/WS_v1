 148:SynaptiX_FDK/services/littlefs/lfs_util.h ****     uint32_t r = 0;
 149:SynaptiX_FDK/services/littlefs/lfs_util.h ****     uint32_t s;
 150:SynaptiX_FDK/services/littlefs/lfs_util.h ****     a -= 1;
 151:SynaptiX_FDK/services/littlefs/lfs_util.h ****     s = (a > 0xffff) << 4; a >>= s; r |= s;
 152:SynaptiX_FDK/services/littlefs/lfs_util.h ****     s = (a > 0xff  ) << 3; a >>= s; r |= s;
