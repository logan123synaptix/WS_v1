 260:SynaptiX_FDK/components/modules/a76xx/a7677s.c **** 
 261:SynaptiX_FDK/components/modules/a76xx/a7677s.c ****     log_info(TAG, "Power On start");
 262:SynaptiX_FDK/components/modules/a76xx/a7677s.c ****     dce->power_state      = A7677S_PWR_PULSE_HIGH;
 263:SynaptiX_FDK/components/modules/a76xx/a7677s.c ****     dce->power_elapsed    = 0;
 264:SynaptiX_FDK/components/modules/a76xx/a7677s.c ****     dce->at_probe_pending = 0;
 265:SynaptiX_FDK/components/modules/a76xx/a7677s.c ****     /* PWRKEY pulse pattern is identical to sim76xx (same physical circuit),
 266:SynaptiX_FDK/components/modules/a76xx/a7677s.c ****      * but here it is driven by state machine timing inside poll() instead
 267:SynaptiX_FDK/components/modules/a76xx/a7677s.c ****      * of sx_delay_ms(), so the main loop is never blocked. */
