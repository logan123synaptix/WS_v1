1335:SynaptiX_FDK/services/fatfs/ff.c **** 		i = val / 8 % SS(fs); bm = 1 << (val % 8);
1336:SynaptiX_FDK/services/fatfs/ff.c **** 		do {
1337:SynaptiX_FDK/services/fatfs/ff.c **** 			do {
