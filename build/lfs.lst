ARM GAS  C:\Users\DELL\AppData\Local\Temp\ccVDvvnW.s 			page 4


 144:SynaptiX_FDK/services/littlefs/lfs.c ****         }
 145:SynaptiX_FDK/services/littlefs/lfs.c **** 
 146:SynaptiX_FDK/services/littlefs/lfs.c ****         int res = memcmp(dat, data + i, diff);
 147:SynaptiX_FDK/services/littlefs/lfs.c ****         if (res) {
 148:SynaptiX_FDK/services/littlefs/lfs.c ****             return res < 0 ? LFS_CMP_LT : LFS_CMP_GT;
 149:SynaptiX_FDK/services/littlefs/lfs.c ****         }
 150:SynaptiX_FDK/services/littlefs/lfs.c ****     }
 151:SynaptiX_FDK/services/littlefs/lfs.c **** 
 152:SynaptiX_FDK/services/littlefs/lfs.c ****     return LFS_CMP_EQ;
 153:SynaptiX_FDK/services/littlefs/lfs.c **** }
