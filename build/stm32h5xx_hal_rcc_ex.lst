5757:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_rcc_ex.c ****   /* Set the SYNCDIV[2:0] bits according to Prescaler value */
5758:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_rcc_ex.c ****   /* Set the SYNCSRC[1:0] bits according to Source value */
