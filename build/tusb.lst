  40:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h **** //--------------------------------------------------------------------+
  41:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h **** // mutex is only needed for RTOS. For OS None, we don't get preempted
  42:SynaptiX_FDK/lib/tinyusb/src/common/tusb_fifo.h **** #define CFG_FIFO_MUTEX      OSAL_MUTEX_REQUIRED
