1363:SynaptiX_FDK/services/fatfs/ff.c **** 	int bv		/* bit value to be set (0 or 1) */
1364:SynaptiX_FDK/services/fatfs/ff.c **** )
1365:SynaptiX_FDK/services/fatfs/ff.c **** {
1366:SynaptiX_FDK/services/fatfs/ff.c **** 	BYTE bm;
1367:SynaptiX_FDK/services/fatfs/ff.c **** 	UINT i;
