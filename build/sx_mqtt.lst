  10:SynaptiX_FDK/components/modules/modem_ops/modem_ops.h **** /*
  11:SynaptiX_FDK/components/modules/modem_ops/modem_ops.h ****  * modem_ops.h
  12:SynaptiX_FDK/components/modules/modem_ops/modem_ops.h ****  *
  13:SynaptiX_FDK/components/modules/modem_ops/modem_ops.h ****  * Common interface (VTABLE) for every modem driver (sim76xx, a7677s, ...).
  14:SynaptiX_FDK/components/modules/modem_ops/modem_ops.h ****  * This is the only contract that the service layer (sx_mqtt.c,
  15:SynaptiX_FDK/components/modules/modem_ops/modem_ops.h ****  * sx_sleep_manager.c, sx_user_mqtt.c) is allowed to know about. The service
  16:SynaptiX_FDK/components/modules/modem_ops/modem_ops.h ****  * layer must NOT include sim76xx.h or a7677s.h directly — every operation
  17:SynaptiX_FDK/components/modules/modem_ops/modem_ops.h ****  * must go through modem_ops_t.
  18:SynaptiX_FDK/components/modules/modem_ops/modem_ops.h ****  *
  19:SynaptiX_FDK/components/modules/modem_ops/modem_ops.h ****  * Design notes:
  20:SynaptiX_FDK/components/modules/modem_ops/modem_ops.h ****  * - No PSM (AT+CPSMS) in this interface. Reason: A7677S has no DTR pin wired
  21:SynaptiX_FDK/components/modules/modem_ops/modem_ops.h ****  *   to the STM32, so it cannot be woken up early while PSM is waiting out
  22:SynaptiX_FDK/components/modules/modem_ops/modem_ops.h ****  *   the T3412 cycle. Use enter_low_power/exit_low_power (AT+CFUN=0/1)
  23:SynaptiX_FDK/components/modules/modem_ops/modem_ops.h ****  *   instead.
  24:SynaptiX_FDK/components/modules/modem_ops/modem_ops.h ****  * - No power-ready signal based on a STATUS pin (A7677S has no STATUS pin
  25:SynaptiX_FDK/components/modules/modem_ops/modem_ops.h ****  *   wired to the STM32 either). Modem readiness must be confirmed via AT/OK
  26:SynaptiX_FDK/components/modules/modem_ops/modem_ops.h ****  *   response, handled internally by the concrete driver (e.g. through a
  27:SynaptiX_FDK/components/modules/modem_ops/modem_ops.h ****  *   POWER_WAIT_BOOT state in its power state machine).
  28:SynaptiX_FDK/components/modules/modem_ops/modem_ops.h ****  * - Every function is non-blocking. No function is allowed to call a
  29:SynaptiX_FDK/components/modules/modem_ops/modem_ops.h ****  *   blocking delay (sx_delay_ms). State must be advanced through poll().
  30:SynaptiX_FDK/components/modules/modem_ops/modem_ops.h ****  */
  31:SynaptiX_FDK/components/modules/modem_ops/modem_ops.h **** 
  32:SynaptiX_FDK/components/modules/modem_ops/modem_ops.h **** /* Result codes at the business/service layer (different from
  33:SynaptiX_FDK/components/modules/modem_ops/modem_ops.h ****  * modem_response_st_t in modem.h, which is the raw AT-command layer result —
  34:SynaptiX_FDK/components/modules/modem_ops/modem_ops.h ****  * this one is already interpreted by the driver). */
  35:SynaptiX_FDK/components/modules/modem_ops/modem_ops.h **** typedef enum {
  36:SynaptiX_FDK/components/modules/modem_ops/modem_ops.h ****     MODEM_OPS_OK = 0,
  37:SynaptiX_FDK/components/modules/modem_ops/modem_ops.h ****     MODEM_OPS_ERROR,
  38:SynaptiX_FDK/components/modules/modem_ops/modem_ops.h ****     MODEM_OPS_TIMEOUT,
  39:SynaptiX_FDK/components/modules/modem_ops/modem_ops.h ****     MODEM_OPS_BUSY          /* modem is busy, request rejected, retry later */
  40:SynaptiX_FDK/components/modules/modem_ops/modem_ops.h **** } modem_ops_result_t;
  41:SynaptiX_FDK/components/modules/modem_ops/modem_ops.h **** 
