1379:SynaptiX_FDK/services/fatfs/ff.c **** 				if (bv == (int)((fs->win[i] & bm) != 0)) return FR_INT_ERR;	/* Is the bit expected value? */
1380:SynaptiX_FDK/services/fatfs/ff.c **** 				fs->win[i] ^= bm;	/* Flip the bit */
