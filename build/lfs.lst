 128:SynaptiX_FDK/services/littlefs/lfs.c **** static int lfs_bd_cmp(lfs_t *lfs,
 129:SynaptiX_FDK/services/littlefs/lfs.c ****         const lfs_cache_t *pcache, lfs_cache_t *rcache, lfs_size_t hint,
 130:SynaptiX_FDK/services/littlefs/lfs.c ****         lfs_block_t block, lfs_off_t off,
 131:SynaptiX_FDK/services/littlefs/lfs.c ****         const void *buffer, lfs_size_t size) {
 132:SynaptiX_FDK/services/littlefs/lfs.c ****     const uint8_t *data = buffer;
 133:SynaptiX_FDK/services/littlefs/lfs.c ****     lfs_size_t diff = 0;
 134:SynaptiX_FDK/services/littlefs/lfs.c **** 
 135:SynaptiX_FDK/services/littlefs/lfs.c ****     for (lfs_off_t i = 0; i < size; i += diff) {
 136:SynaptiX_FDK/services/littlefs/lfs.c ****         uint8_t dat[8];
 137:SynaptiX_FDK/services/littlefs/lfs.c **** 
 138:SynaptiX_FDK/services/littlefs/lfs.c ****         diff = lfs_min(size-i, sizeof(dat));
 139:SynaptiX_FDK/services/littlefs/lfs.c ****         int err = lfs_bd_read(lfs,
 140:SynaptiX_FDK/services/littlefs/lfs.c ****                 pcache, rcache, hint-i,
 141:SynaptiX_FDK/services/littlefs/lfs.c ****                 block, off+i, &dat, diff);
 142:SynaptiX_FDK/services/littlefs/lfs.c ****         if (err) {
