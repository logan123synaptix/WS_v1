  43:SynaptiX_FDK/board/sx_board.c **** static sx_gpio_pin_t s_lte_pwrkey_pin = {.pin = LTE_PWRKEY_Pin, .port = LTE_PWRKEY_Port};
  44:SynaptiX_FDK/board/sx_board.c **** /* LTE_RESET_Pin (GPIOD PIN_11) — per schematic, drives Q2's base through
  45:SynaptiX_FDK/board/sx_board.c ****  * R17 (open-collector style switch to GND on the module's own RESET pin).
  46:SynaptiX_FDK/board/sx_board.c ****  * MCU HIGH -> Q2 on -> module's RESET pin pulled low (native active-low
  47:SynaptiX_FDK/board/sx_board.c ****  * reset). MCU LOW (default/idle, R19 pulls Q2's base down, CubeMX also
  48:SynaptiX_FDK/board/sx_board.c ****  * inits this pin LOW at boot) -> Q2 off -> module's RESET pin floats high
  49:SynaptiX_FDK/board/sx_board.c ****  * via its internal VBAT pull-up -> normal operation. Used only by
  50:SynaptiX_FDK/board/sx_board.c ****  * a7677s_hard_reset() (modem_ops_t.hard_reset) as a last-resort escalation
  51:SynaptiX_FDK/board/sx_board.c ****  * when the normal PWRKEY power_off_start()/power_on_start() cycle has
  52:SynaptiX_FDK/board/sx_board.c ****  * itself failed to recover the modem, or it has stopped responding to AT
  53:SynaptiX_FDK/board/sx_board.c ****  * entirely — not a routine recovery path. See a7677s_t.resetPin's
  54:SynaptiX_FDK/board/sx_board.c ****  * doc-comment in a7677s.h for the full timing/state-machine details. */
  55:SynaptiX_FDK/board/sx_board.c **** static sx_gpio_pin_t s_lte_reset_pin = {.pin = LTE_RESET_Pin, .port = LTE_RESET_Port};
  56:SynaptiX_FDK/board/sx_board.c **** 
  57:SynaptiX_FDK/board/sx_board.c **** /* No VBAT-cutoff transistor on this board revision for the modem — see
  58:SynaptiX_FDK/board/sx_board.c ****  * a7677s_t.hasPowerPin (set to 0 below). A future board revision may add
  59:SynaptiX_FDK/board/sx_board.c ****  * one back, hence the field stays in modem_t/a7677s_t rather than being
  60:SynaptiX_FDK/board/sx_board.c ****  * removed outright (see modem.h's own comment on hasPowerPin/powerPin). */
  61:SynaptiX_FDK/board/sx_board.c **** 
  62:SynaptiX_FDK/board/sx_board.c **** static sx_gpio_pin_t s_gps_cpw_pin = {.pin = GPS_CPW_Pin, .port = GPS_CPW_Port};
  63:SynaptiX_FDK/board/sx_board.c **** static sx_gpio_pin_t s_gps_rst_pin = {.pin = GPS_RST_Pin, .port = GPS_RST_Port};
  64:SynaptiX_FDK/board/sx_board.c **** /* GPS_PPS_Pin is wired but not used by this firmware yet (no 1PPS capture
  65:SynaptiX_FDK/board/sx_board.c ****  * configured) — no sx_gpio_pin_t declared for it, nothing to pass around
  66:SynaptiX_FDK/board/sx_board.c ****  * until that feature is implemented. */
  67:SynaptiX_FDK/board/sx_board.c **** 
  68:SynaptiX_FDK/board/sx_board.c **** static sx_gpio_pin_t s_spi_cs_pin = {.pin = SPI_CS_Pin, .port = SPI_CS_Port};
  69:SynaptiX_FDK/board/sx_board.c **** 
  70:SynaptiX_FDK/board/sx_board.c **** /* RTC and IMU share the same physical reset line (I2C1_RESET_Pin) per the
  71:SynaptiX_FDK/board/sx_board.c ****  * schematic — one wire, not two independent pins. RTC does not use it at
  72:SynaptiX_FDK/board/sx_board.c ****  * all (rx8130ce_init() resets itself via an I2C register sequence per the
  73:SynaptiX_FDK/board/sx_board.c ****  * datasheet, see sx_ex_rtc.c's _software_reset()); only IMU takes this GPIO
  74:SynaptiX_FDK/board/sx_board.c ****  * as its reset_gpio. Kept as a single sx_gpio_t rather than one per
  75:SynaptiX_FDK/board/sx_board.c ****  * consumer, since writing it from two independent handles for what is one
  76:SynaptiX_FDK/board/sx_board.c ****  * physical wire invites the two drivers stepping on each other. */
  77:SynaptiX_FDK/board/sx_board.c **** static sx_gpio_t     s_i2c1_reset;
  78:SynaptiX_FDK/board/sx_board.c **** static sx_gpio_pin_t s_i2c1_reset_pin = {.pin = I2C1_RESET_Pin, .port = I2C1_RESET_Port};
  79:SynaptiX_FDK/board/sx_board.c **** 
  80:SynaptiX_FDK/board/sx_board.c **** /* RS485_RDE_Pin is wired (see sx_board.h) but not yet driven by any init
  81:SynaptiX_FDK/board/sx_board.c ****  * call in this file — left undeclared here rather than adding an unused
  82:SynaptiX_FDK/board/sx_board.c ****  * sx_gpio_t/sx_gpio_pin_t pair for a pin nothing reads or writes yet. */
  83:SynaptiX_FDK/board/sx_board.c **** 
  84:SynaptiX_FDK/board/sx_board.c **** /* SPS30 power enable — see EN_PW_DUST_Pin's doc-comment in sx_board.h for
  85:SynaptiX_FDK/board/sx_board.c ****  * the full opto/MOSFET chain and active-HIGH polarity. Defaults LOW at
  86:SynaptiX_FDK/board/sx_board.c ****  * boot (CubeMX's MX_GPIO_Init resets it low before this file ever runs),
ARM GAS  C:\Users\DELL\AppData\Local\Temp\ccSsJ5lh.s 			page 3


  87:SynaptiX_FDK/board/sx_board.c ****  * so SPS30 stays unpowered until something explicitly drives it HIGH —
  88:SynaptiX_FDK/board/sx_board.c ****  * that on/off sequencing belongs to the SPS30 business-logic layer
  89:SynaptiX_FDK/board/sx_board.c ****  * (not yet written), not to board bring-up, so it is only declared here. */
  90:SynaptiX_FDK/board/sx_board.c **** static sx_gpio_t     s_en_pw_dust;
