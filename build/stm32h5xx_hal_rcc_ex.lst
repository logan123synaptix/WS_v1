5771:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_rcc_ex.c ****   /* START AUTOMATIC SYNCHRONIZATION*/
5772:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_rcc_ex.c **** 
5773:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_rcc_ex.c ****   /* Enable Automatic trimming & Frequency error counter */
