1371:SynaptiX_FDK/services/fatfs/ff.c **** 	clst -= 2;	/* The first bit corresponds to cluster #2 */
1372:SynaptiX_FDK/services/fatfs/ff.c **** 	sect = fs->bitbase + clst / 8 / SS(fs);	/* Sector address */
