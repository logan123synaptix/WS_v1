{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug STM32H5 (ST-LINK)",
            "type": "cortex-debug",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/debug/BOOTLOADER_WS.elf",
            "servertype": "stlink",
            "serverpath": "D:\\stm32cubeclt\\STM32CubeCLT_1.21.0\\STLink-gdb-server\\bin\\ST-LINK_gdbserver.exe",
            "device": "STM32H563RIVx",
            "interface": "swd",
            "runToEntryPoint": "main",
            "gdbPath": "D:/stm32cubeclt/STM32CubeCLT_1.21.0/GNU-tools-for-STM32/bin/arm-none-eabi-gdb.exe",
            "stm32cubeprogrammer": "D:\\stm32cubeclt\\STM32CubeCLT_1.21.0\\STM32CubeProgrammer\\bin",
            "showDevDebugOutput": "none",
            "serverArgs": ["-m", "1"]
        }
    ]
}