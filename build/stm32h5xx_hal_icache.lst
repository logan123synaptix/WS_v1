 163:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_icache.c **** /**
 164:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_icache.c ****   * @brief  Configure the Instruction Cache cache associativity mode selection.
 165:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_icache.c ****   * @param  AssociativityMode  Associativity mode selection
 166:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_icache.c ****   *         This parameter can be one of the following values:
 167:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_icache.c ****   *            @arg ICACHE_1WAY   1-way cache (direct mapped cache)
 168:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_icache.c ****   *            @arg ICACHE_2WAYS  2-ways set associative cache (default)
 169:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_icache.c ****   * @retval HAL status (HAL_OK/HAL_ERROR)
 170:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_icache.c ****   */
 171:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_icache.c **** HAL_StatusTypeDef HAL_ICACHE_ConfigAssociativityMode(uint32_t AssociativityMode)
 172:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_icache.c **** {
  31              		.loc 1 172 1 view -0
  32              		.cfi_startproc
  33              		@ args = 0, pretend = 0, frame = 0
