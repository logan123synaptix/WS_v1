  48:SynaptiX_FDK/lib/tinyusb/src/portable/st/stm32_fsdev/fsdev_common.h **** // Vendor-independent definitions with U_ prefix to avoid conflicts.
  49:SynaptiX_FDK/lib/tinyusb/src/portable/st/stm32_fsdev/fsdev_common.h **** // Based on the common USB FSDEV IP block register layout.
  50:SynaptiX_FDK/lib/tinyusb/src/portable/st/stm32_fsdev/fsdev_common.h **** // Lower 16 bits are shared across all variants (STM32, CH32, AT32).
  51:SynaptiX_FDK/lib/tinyusb/src/portable/st/stm32_fsdev/fsdev_common.h **** // Upper 16 bits (DRD extensions) only exist on 32-bit DRD MCUs.
