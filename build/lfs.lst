 143:SynaptiX_FDK/services/littlefs/lfs_util.h **** // Find the smallest power of 2 greater than or equal to a
 144:SynaptiX_FDK/services/littlefs/lfs_util.h **** static inline uint32_t lfs_npw2(uint32_t a) {
 145:SynaptiX_FDK/services/littlefs/lfs_util.h **** #if !defined(LFS_NO_INTRINSICS) && (defined(__GNUC__) || defined(__CC_ARM))
