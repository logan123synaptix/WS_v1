  31:SynaptiX_FDK/services/littlefs/lfs.c **** static inline void lfs_cache_drop(lfs_t *lfs, lfs_cache_t *rcache) {
  32:SynaptiX_FDK/services/littlefs/lfs.c ****     // do not zero, cheaper if cache is readonly or only going to be
  33:SynaptiX_FDK/services/littlefs/lfs.c ****     // written with identical data (during relocates)
  34:SynaptiX_FDK/services/littlefs/lfs.c ****     (void)lfs;
  35:SynaptiX_FDK/services/littlefs/lfs.c ****     rcache->block = LFS_BLOCK_NULL;
  36:SynaptiX_FDK/services/littlefs/lfs.c **** }
  37:SynaptiX_FDK/services/littlefs/lfs.c **** 
  38:SynaptiX_FDK/services/littlefs/lfs.c **** static inline void lfs_cache_zero(lfs_t *lfs, lfs_cache_t *pcache) {
  39:SynaptiX_FDK/services/littlefs/lfs.c ****     // zero to avoid information leak
  40:SynaptiX_FDK/services/littlefs/lfs.c ****     memset(pcache->buffer, 0xff, lfs->cfg->cache_size);
  41:SynaptiX_FDK/services/littlefs/lfs.c ****     pcache->block = LFS_BLOCK_NULL;
  42:SynaptiX_FDK/services/littlefs/lfs.c **** }
  43:SynaptiX_FDK/services/littlefs/lfs.c **** 
  44:SynaptiX_FDK/services/littlefs/lfs.c **** static int lfs_bd_read(lfs_t *lfs,
  45:SynaptiX_FDK/services/littlefs/lfs.c ****         const lfs_cache_t *pcache, lfs_cache_t *rcache, lfs_size_t hint,
  46:SynaptiX_FDK/services/littlefs/lfs.c ****         lfs_block_t block, lfs_off_t off,
  47:SynaptiX_FDK/services/littlefs/lfs.c ****         void *buffer, lfs_size_t size) {
  48:SynaptiX_FDK/services/littlefs/lfs.c ****     uint8_t *data = buffer;
  49:SynaptiX_FDK/services/littlefs/lfs.c ****     if (off+size > lfs->cfg->block_size
  50:SynaptiX_FDK/services/littlefs/lfs.c ****             || (lfs->block_count && block >= lfs->block_count)) {
  51:SynaptiX_FDK/services/littlefs/lfs.c ****         return LFS_ERR_CORRUPT;
  52:SynaptiX_FDK/services/littlefs/lfs.c ****     }
  53:SynaptiX_FDK/services/littlefs/lfs.c **** 
  54:SynaptiX_FDK/services/littlefs/lfs.c ****     while (size > 0) {
  55:SynaptiX_FDK/services/littlefs/lfs.c ****         lfs_size_t diff = size;
  56:SynaptiX_FDK/services/littlefs/lfs.c **** 
  57:SynaptiX_FDK/services/littlefs/lfs.c ****         if (pcache && block == pcache->block &&
  58:SynaptiX_FDK/services/littlefs/lfs.c ****                 off < pcache->off + pcache->size) {
  59:SynaptiX_FDK/services/littlefs/lfs.c ****             if (off >= pcache->off) {
  60:SynaptiX_FDK/services/littlefs/lfs.c ****                 // is already in pcache?
  61:SynaptiX_FDK/services/littlefs/lfs.c ****                 diff = lfs_min(diff, pcache->size - (off-pcache->off));
  62:SynaptiX_FDK/services/littlefs/lfs.c ****                 memcpy(data, &pcache->buffer[off-pcache->off], diff);
  63:SynaptiX_FDK/services/littlefs/lfs.c **** 
  64:SynaptiX_FDK/services/littlefs/lfs.c ****                 data += diff;
  65:SynaptiX_FDK/services/littlefs/lfs.c ****                 off += diff;
  66:SynaptiX_FDK/services/littlefs/lfs.c ****                 size -= diff;
  67:SynaptiX_FDK/services/littlefs/lfs.c ****                 continue;
  68:SynaptiX_FDK/services/littlefs/lfs.c ****             }
  69:SynaptiX_FDK/services/littlefs/lfs.c **** 
  70:SynaptiX_FDK/services/littlefs/lfs.c ****             // pcache takes priority
  71:SynaptiX_FDK/services/littlefs/lfs.c ****             diff = lfs_min(diff, pcache->off-off);
  72:SynaptiX_FDK/services/littlefs/lfs.c ****         }
  73:SynaptiX_FDK/services/littlefs/lfs.c **** 
  74:SynaptiX_FDK/services/littlefs/lfs.c ****         if (block == rcache->block &&
  75:SynaptiX_FDK/services/littlefs/lfs.c ****                 off < rcache->off + rcache->size) {
  76:SynaptiX_FDK/services/littlefs/lfs.c ****             if (off >= rcache->off) {
  77:SynaptiX_FDK/services/littlefs/lfs.c ****                 // is already in rcache?
  78:SynaptiX_FDK/services/littlefs/lfs.c ****                 diff = lfs_min(diff, rcache->size - (off-rcache->off));
  79:SynaptiX_FDK/services/littlefs/lfs.c ****                 memcpy(data, &rcache->buffer[off-rcache->off], diff);
  80:SynaptiX_FDK/services/littlefs/lfs.c **** 
  81:SynaptiX_FDK/services/littlefs/lfs.c ****                 data += diff;
  82:SynaptiX_FDK/services/littlefs/lfs.c ****                 off += diff;
  83:SynaptiX_FDK/services/littlefs/lfs.c ****                 size -= diff;
  84:SynaptiX_FDK/services/littlefs/lfs.c ****                 continue;
  85:SynaptiX_FDK/services/littlefs/lfs.c ****             }
  86:SynaptiX_FDK/services/littlefs/lfs.c **** 
ARM GAS  C:\Users\DELL\AppData\Local\Temp\ccVDvvnW.s 			page 3


  87:SynaptiX_FDK/services/littlefs/lfs.c ****             // rcache takes priority
  88:SynaptiX_FDK/services/littlefs/lfs.c ****             diff = lfs_min(diff, rcache->off-off);
  89:SynaptiX_FDK/services/littlefs/lfs.c ****         }
  90:SynaptiX_FDK/services/littlefs/lfs.c **** 
  91:SynaptiX_FDK/services/littlefs/lfs.c ****         if (size >= hint && off % lfs->cfg->read_size == 0 &&
  92:SynaptiX_FDK/services/littlefs/lfs.c ****                 size >= lfs->cfg->read_size) {
  93:SynaptiX_FDK/services/littlefs/lfs.c ****             // bypass cache?
  94:SynaptiX_FDK/services/littlefs/lfs.c ****             diff = lfs_aligndown(diff, lfs->cfg->read_size);
  95:SynaptiX_FDK/services/littlefs/lfs.c ****             int err = lfs->cfg->read(lfs->cfg, block, off, data, diff);
  96:SynaptiX_FDK/services/littlefs/lfs.c ****             LFS_ASSERT(err <= 0);
  97:SynaptiX_FDK/services/littlefs/lfs.c ****             if (err) {
  98:SynaptiX_FDK/services/littlefs/lfs.c ****                 return err;
  99:SynaptiX_FDK/services/littlefs/lfs.c ****             }
 100:SynaptiX_FDK/services/littlefs/lfs.c **** 
 101:SynaptiX_FDK/services/littlefs/lfs.c ****             data += diff;
 102:SynaptiX_FDK/services/littlefs/lfs.c ****             off += diff;
 103:SynaptiX_FDK/services/littlefs/lfs.c ****             size -= diff;
 104:SynaptiX_FDK/services/littlefs/lfs.c ****             continue;
 105:SynaptiX_FDK/services/littlefs/lfs.c ****         }
 106:SynaptiX_FDK/services/littlefs/lfs.c **** 
 107:SynaptiX_FDK/services/littlefs/lfs.c ****         // load to cache, first condition can no longer fail
 108:SynaptiX_FDK/services/littlefs/lfs.c ****         LFS_ASSERT(!lfs->block_count || block < lfs->block_count);
 109:SynaptiX_FDK/services/littlefs/lfs.c ****         rcache->block = block;
 110:SynaptiX_FDK/services/littlefs/lfs.c ****         rcache->off = lfs_aligndown(off, lfs->cfg->read_size);
 111:SynaptiX_FDK/services/littlefs/lfs.c ****         rcache->size = lfs_min(
 112:SynaptiX_FDK/services/littlefs/lfs.c ****                 lfs_min(
 113:SynaptiX_FDK/services/littlefs/lfs.c ****                     lfs_alignup(off+hint, lfs->cfg->read_size),
 114:SynaptiX_FDK/services/littlefs/lfs.c ****                     lfs->cfg->block_size)
 115:SynaptiX_FDK/services/littlefs/lfs.c ****                 - rcache->off,
 116:SynaptiX_FDK/services/littlefs/lfs.c ****                 lfs->cfg->cache_size);
 117:SynaptiX_FDK/services/littlefs/lfs.c ****         int err = lfs->cfg->read(lfs->cfg, rcache->block,
 118:SynaptiX_FDK/services/littlefs/lfs.c ****                 rcache->off, rcache->buffer, rcache->size);
 119:SynaptiX_FDK/services/littlefs/lfs.c ****         LFS_ASSERT(err <= 0);
 120:SynaptiX_FDK/services/littlefs/lfs.c ****         if (err) {
 121:SynaptiX_FDK/services/littlefs/lfs.c ****             return err;
 122:SynaptiX_FDK/services/littlefs/lfs.c ****         }
 123:SynaptiX_FDK/services/littlefs/lfs.c ****     }
 124:SynaptiX_FDK/services/littlefs/lfs.c **** 
 125:SynaptiX_FDK/services/littlefs/lfs.c ****     return 0;
 126:SynaptiX_FDK/services/littlefs/lfs.c **** }
