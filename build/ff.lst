1319:SynaptiX_FDK/services/fatfs/ff.c **** static DWORD find_bitmap (	/* 0:Not found, 2..:Cluster block found, 0xFFFFFFFF:Disk error */
1320:SynaptiX_FDK/services/fatfs/ff.c **** 	FATFS* fs,	/* Filesystem object */
