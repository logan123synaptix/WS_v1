  46:SynaptiX_FDK/services/fatfs/ff.c **** /* Character code support macros */
  47:SynaptiX_FDK/services/fatfs/ff.c **** #define IsUpper(c)		((c) >= 'A' && (c) <= 'Z')
  48:SynaptiX_FDK/services/fatfs/ff.c **** #define IsLower(c)		((c) >= 'a' && (c) <= 'z')
  49:SynaptiX_FDK/services/fatfs/ff.c **** #define IsDigit(c)		((c) >= '0' && (c) <= '9')
  50:SynaptiX_FDK/services/fatfs/ff.c **** #define IsSeparator(c)	((c) == '/' || (c) == '\\')
  51:SynaptiX_FDK/services/fatfs/ff.c **** #define IsTerminator(c)	((UINT)(c) < (FF_USE_LFN ? ' ' : '!'))
  52:SynaptiX_FDK/services/fatfs/ff.c **** #define IsSurrogate(c)	((c) >= 0xD800 && (c) <= 0xDFFF)
  53:SynaptiX_FDK/services/fatfs/ff.c **** #define IsSurrogateH(c)	((c) >= 0xD800 && (c) <= 0xDBFF)
  54:SynaptiX_FDK/services/fatfs/ff.c **** #define IsSurrogateL(c)	((c) >= 0xDC00 && (c) <= 0xDFFF)
  55:SynaptiX_FDK/services/fatfs/ff.c **** 
