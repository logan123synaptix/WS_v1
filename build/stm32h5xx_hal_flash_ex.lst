  41:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_flash_ex.c ****                         ##### How to use this driver #####
  42:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_flash_ex.c ****  ==============================================================================
  43:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_flash_ex.c ****   [..] This driver provides functions to configure and program the FLASH memory
  44:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_flash_ex.c ****        of all STM32H5xx devices. It includes
  45:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_flash_ex.c ****       (#) FLASH Memory Erase functions:
  46:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_flash_ex.c ****            (++) Lock and Unlock the FLASH interface using HAL_FLASH_Unlock() and
  47:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_flash_ex.c ****                 HAL_FLASH_Lock() functions
  48:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_flash_ex.c ****            (++) Erase function: Sector erase, bank erase and dual-bank mass erase
  49:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_flash_ex.c ****            (++) There are two modes of erase :
  50:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_flash_ex.c ****              (+++) Polling Mode using HAL_FLASHEx_Erase()
  51:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_flash_ex.c ****              (+++) Interrupt Mode using HAL_FLASHEx_Erase_IT()
  52:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_flash_ex.c **** 
  53:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_flash_ex.c ****       (#) Option Bytes Programming functions: Use HAL_FLASHEx_OBProgram() to:
  54:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_flash_ex.c ****         (++) Configure the write protection per bank
  55:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_flash_ex.c ****         (++) Set the Product State
  56:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_flash_ex.c ****         (++) Program the user Option Bytes
  57:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_flash_ex.c ****         (++) Configure the watermark security for each area
  58:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_flash_ex.c ****         (++) Configure the Hide protection areas
  59:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_flash_ex.c ****         (++) Configure the Boot addresses
  60:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_flash_ex.c **** 
  61:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_flash_ex.c ****       (#) Get Option Bytes Configuration function: Use HAL_FLASHEx_OBGetConfig() to:
  62:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_flash_ex.c ****         (++) Get the value of a write protection area
  63:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_flash_ex.c ****         (++) Get the Product State
  64:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_flash_ex.c ****         (++) Get the value of the user Option Bytes
  65:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_flash_ex.c ****         (++) Get the configuration of watermark security areas
  66:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_flash_ex.c ****         (++) Get the configuration of Hide protection areas
  67:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_flash_ex.c ****         (++) Get the value of a boot address
  68:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_flash_ex.c **** 
  69:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_flash_ex.c ****       (#) Block-based secure / privilege area configuration function: Use HAL_FLASHEx_ConfigBBAttri
  70:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_flash_ex.c ****         (++) Bit-field allowing to secure or un-secure each sector
  71:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_flash_ex.c ****         (++) Bit-field allowing to privilege or un-privilege each sector
  72:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_flash_ex.c **** 
  73:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_flash_ex.c ****       (#) Get the block-based secure / privilege area configuration function: Use HAL_FLASHEx_GetCo
  74:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_flash_ex.c ****         (++) Return the configuration of the block-based security and privilege for all the sectors
  75:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_flash_ex.c **** 
  76:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_flash_ex.c ****       (#) Privilege mode configuration function: Use HAL_FLASHEx_ConfigPrivMode()
  77:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_flash_ex.c ****         (++) FLASH register can be protected against non-privilege accesses
  78:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_flash_ex.c **** 
  79:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_flash_ex.c ****       (#) Get the privilege mode configuration function: Use HAL_FLASHEx_GetPrivMode()
  80:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_flash_ex.c ****         (++) Return if the FLASH registers are protected against non-privilege accesses
  81:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_flash_ex.c **** 
  82:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_flash_ex.c **** 
  83:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_flash_ex.c ****  @endverbatim
  84:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_flash_ex.c ****   */
